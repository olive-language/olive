fn read_file(path: str) -> str:
    let content = __olive_file_read(path)
    # 0 indicates read failure in the backend
    if content == 0:
        return ""
    return content

fn write_file(path: str, data: str) -> bool:
    let res = __olive_file_write(path, data)
    return res == 1

fn print_line(msg: str):
    print(msg)
