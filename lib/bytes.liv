    return __olive_buf_read_u32_le(buf, offset)

fn read_u32_be(buf: int, offset: int) -> int:
    return __olive_buf_read_u32_be(buf, offset)

fn read_u64_le(buf: int, offset: int) -> int:
    return __olive_buf_read_u64_le(buf, offset)

fn read_u64_be(buf: int, offset: int) -> int:
    return __olive_buf_read_u64_be(buf, offset)

fn write_u16_le(buf: int, offset: int, val: int):
    __olive_buf_write_u16_le(buf, offset, val)

fn write_u16_be(buf: int, offset: int, val: int):
    __olive_buf_write_u16_be(buf, offset, val)

fn write_u32_le(buf: int, offset: int, val: int):
